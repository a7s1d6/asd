rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return request.auth.token.email_verified == true; }
    function isAdmin() { 
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }
    function isVerifiedAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'wwmmww716@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      ); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /test/{docId} {
      allow read: if true;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isVerifiedAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isVerifiedAdmin();
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow write: if isSignedIn() && isEmailVerified();
      }
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isVerifiedAdmin();
    }

    match /orders/{orderId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isVerifiedAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isVerifiedAdmin();
    }

    match /coupons/{couponId} {
      allow read: if isSignedIn();
      allow write: if isVerifiedAdmin();
    }

    match /analytics/{doc=**} {
      allow read, write: if isVerifiedAdmin();
    }
  }
}
